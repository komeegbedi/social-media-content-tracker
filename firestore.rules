rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    function myDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isAdmin() {
      return hasProfile() && myDoc().role == 'admin';
    }
    function isApproved() {
      return hasProfile() && (myDoc().status == 'approved' || myDoc().role == 'admin');
    }
    function isQA() {
      return hasProfile() && (myDoc().qa == true || myDoc().role == 'admin');
    }

    match /users/{uid} {
      // Read your own profile always; read others only once you're approved.
      allow get: if signedIn() && (request.auth.uid == uid || isApproved());
      allow list: if isApproved();

      // On registration you may create ONLY your own doc, and only as a
      // pending member — you cannot make yourself an admin or pre-approved,
      // nor grant yourself the QA / captions roles. Privileges are admin-only.
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role == 'member'
        && request.resource.data.status == 'pending'
        && request.resource.data.get('qa', false) == false
        && request.resource.data.get('captions', false) == false
        && request.resource.data.get('lead', false) == false;

      // Admins edit profiles (approvals, roles, skills, flags, removal).
      // Members may self-edit ONLY their notification preferences — nothing
      // else (changing their own skills/flags could game auto-assignment).
      allow update: if isAdmin()
        || (signedIn() && request.auth.uid == uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notifPrefs']));
      allow delete: if isAdmin();

      // Web-push device tokens: a user manages only their own.
      match /fcmTokens/{token} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }

    // In-app notifications. Written server-side (Admin SDK bypasses rules);
    // a user may read only their own and mark them read — nothing else.
    match /notifications/{id} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if signedIn() && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    // Materialized reminder queue — entirely server-owned. Admins may read it
    // for the delivery log; no client ever writes it.
    match /reminderInstances/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Email delivery ledger (Resend) — written server-side only; admins read
    // it for the delivery log. Never client-writable.
    match /emailDeliveries/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Email usage counters (monthly/daily quota). Server-managed; admins read
    // for the usage dashboard. Never client-writable — the hard limit can't be
    // altered from the frontend.
    match /systemUsage/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // App-wide settings (e.g. default reminder schedule, leadership roles).
    match /settings/{docId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isApproved();

      // Only admins create or delete tasks.
      allow create, delete: if isAdmin();

      // Admins can change anything. Approved members may only touch
      // collaboration fields — status, comments, reactions, and the
      // "what's next / waiting on" fields — not reassign crew, owners,
      // dates, priority, etc.
      // ...plus content links, captions/post link, and the activity log.
      // The QA-decision transitions ("Approved" and "Changes Requested") can
      // only be made by a QA member or an admin.
      allow update: if isAdmin()
        || (isApproved()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'comments', 'reactions', 'updatedAt',
                           'blockedOn', 'links', 'activity', 'caption', 'postLink'])
            && (request.resource.data.status == resource.data.status
                || !(request.resource.data.status in ['Approved', 'Changes Requested'])
                || isQA()));

      // Comments as a subcollection (v1.1). Approved members read all and may
      // post their own; edits/removal are admin-only. Enables the server-side
      // @mention trigger without bloating the task document.
      match /comments/{commentId} {
        allow read: if isApproved();
        allow create: if isApproved() && request.resource.data.uid == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // Issue log: user-filed reports and auto-captured runtime errors.
    match /issues/{id} {
      // Any signed-in user may file an issue, but only under their own uid
      // (can't spoof someone else). Errors are logged the same way.
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      // Only admins can read the log, triage (resolve), or delete.
      allow read, update, delete: if isAdmin();
    }
  }
}
